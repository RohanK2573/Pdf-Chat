# Server runtime
NODE_ENV=production
PORT=8000

# RDS PostgreSQL
DATABASE_URL=postgresql://<db_user>:<db_password>@<rds-endpoint>:5432/<db_name>

# Queue + Vector DB (running on EC2)
REDIS_HOST=localhost
REDIS_PORT=6379
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=pdf-embeddings-768

# Auth (Clerk)
CLERK_JWT_ISSUER=https://<your-clerk-instance>
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTY=https://app.<your-domain>

# Model providers
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini
CHAT_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
GOOGLE_API_KEY=
# OPENAI_API_KEY=

# S3
AWS_REGION=<aws-region>
S3_BUCKET_NAME=<bucket-name>
# Leave keys empty when using EC2 instance profile role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
